# Copy to functions/.env and fill in. These are non-secret config (the client_id is public).
# The CLIENT SECRET is NOT here — set it with: firebase functions:secrets:set REDDIT_CLIENT_SECRET

# From your Reddit app at https://www.reddit.com/prefs/apps (type: "web app")
REDDIT_CLIENT_ID=your_reddit_client_id

# Must EXACTLY match the redirect URI registered in the Reddit app AND the front-end's
# VITE_REDDIT_REDIRECT_URI. It is this function's deployed URL, e.g.:
#   https://us-central1-leadqonnect.cloudfunctions.net/redditCallback
REDDIT_REDIRECT_URI=https://us-central1-leadqonnect.cloudfunctions.net/redditCallback

# Where users are sent back after connecting (your app's URL).
# Local dev example: http://localhost:5173   |   Prod: https://leadqonnect.web.app
APP_URL=http://localhost:5173

# --- Gmail connection (OAuth) ---  see GMAIL_SETUP.md
# From a Google Cloud project → APIs & Services → Credentials → OAuth 2.0 Client ID
# (type: "Web application"). Enable the Gmail API on the project too.
# The CLIENT SECRET is NOT here — set it with:
#   firebase functions:secrets:set GOOGLE_CLIENT_SECRET
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# Must EXACTLY match an "Authorized redirect URI" on the OAuth client AND the front-end's
# VITE_GOOGLE_REDIRECT_URI. Stable hosting URL (rewrites to the gmailCallback function):
#   https://leadqonnect.web.app/gmailCallback
GOOGLE_REDIRECT_URI=https://leadqonnect.web.app/gmailCallback

# --- AI lead qualification (Claude) ---
# The API KEY is a secret — do NOT put it here. Set it with:
#   firebase functions:secrets:set ANTHROPIC_API_KEY
# Model is non-secret config. Default claude-opus-4-8 (most precise).
# claude-haiku-4-5 cuts cost ~5x; claude-sonnet-4-6 is a middle ground.
LEAD_AI_MODEL=claude-opus-4-8

# --- Razorpay billing (recurring subscriptions, USD) ---  see RAZORPAY_SETUP.md
# KEY_ID is public (it's returned to the browser). The KEY_SECRET and WEBHOOK_SECRET
# are secrets — do NOT put them here. Set them with:
#   firebase functions:secrets:set RAZORPAY_KEY_SECRET
#   firebase functions:secrets:set RAZORPAY_WEBHOOK_SECRET
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# Subscription plan ids (USD) created once in Razorpay — via the dashboard or:
#   node scripts/create-razorpay-plans.mjs
RAZORPAY_PLAN_ID_PRO=plan_xxxxxxxxxxxxxx
RAZORPAY_PLAN_ID_AGENCY=plan_xxxxxxxxxxxxxx
