# --- Turso (free tier: https://turso.tech) -----------------------------------
# Create a DB:  turso db create leadfinder
# URL:          turso db show leadfinder --url
# Token:        turso db tokens create leadfinder
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_token

# --- Gemini (free tier: https://aistudio.google.com/apikey) -------------------
# Leave GEMINI_API_KEY empty to skip AI scoring and use the deterministic scorer only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# --- Reddit (NO API KEY NEEDED) -----------------------------------------------
# We use Reddit's public JSON endpoints. Just set a descriptive User-Agent so we
# are not throttled as an anonymous bot. Format: platform:app:version (by /u/you)
REDDIT_USER_AGENT=web:leadfinder:0.1 (by /u/your_reddit_username)

# --- Dashboard access gate (optional but recommended for a public Vercel URL) -
# If set, the API and dashboard require this token (sent as x-access-token).
# Leave empty for an open dashboard (fine for a private/unshared URL).
DASHBOARD_TOKEN=
