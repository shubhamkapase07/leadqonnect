{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "codebase": "default",
    "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/redditCallback", "function": "redditCallback" },
      { "source": "/gmailCallback", "function": "gmailCallback" },
      { "source": "/razorpayWebhook", "function": "razorpayWebhook" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
