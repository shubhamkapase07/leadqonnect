# --- Lead scanning (Apify) — SERVER-SIDE ONLY ---
# Scraping now runs inside the `scrapeLeads` Cloud Function, so the Apify token never ships
# in the browser bundle. Set it as a Functions secret (NOT a VITE_ var), then deploy:
#   firebase functions:secrets:set APIFY_TOKEN
# Optional actor/cost overrides go in functions/.env (no VITE_ prefix):
#   APIFY_MAX_ITEMS=10
#   APIFY_MAX_COST_USD=0.3
#   APIFY_ACTOR_REDDIT=trudax~reddit-scraper-lite
#   APIFY_ACTOR_TWITTER=kaitoeasyapi~twitter-x-data-tweet-scraper-pay-per-result-cheapest
#   APIFY_ACTOR_LINKEDIN=harvestapi~linkedin-post-search
#
# --- Reddit account connection (OAuth) ---
# Lets users sign in with Reddit and reply/DM leads from their own account.
# Requires the Cloud Functions in /functions to be deployed (see REDDIT_SETUP.md).
# CLIENT_ID is public (safe in the client). The client SECRET lives only in Functions.
VITE_REDDIT_CLIENT_ID=your_reddit_client_id
# Must match functions REDDIT_REDIRECT_URI + the Reddit app's redirect URI exactly:
VITE_REDDIT_REDIRECT_URI=https://us-central1-leadqonnect.cloudfunctions.net/redditCallback

# --- Gmail account connection (OAuth) ---
# Lets users connect Google and send email from their own address (scope gmail.send only).
# Requires the Cloud Functions in /functions to be deployed (see GMAIL_SETUP.md).
# CLIENT_ID is public (safe in the client). The client SECRET lives only in Functions.
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# Must match functions GOOGLE_REDIRECT_URI + the OAuth client's redirect URI exactly:
VITE_GOOGLE_REDIRECT_URI=https://leadqonnect.web.app/gmailCallback

# Firebase configuration (required for auth + database).
# Copy this file to .env.local and fill in your Firebase project values.
# .env.local is gitignored — never commit real credentials.

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
